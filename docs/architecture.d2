    font-color: "#ffffff"
    stroke: "#1e4d8c"
    border-radius: 10
  }
}

Parser: {
  label: "Parser\nparser.py\nRecursive descent"
  style: {
    fill: "#285faa"
    font-color: "#ffffff"
    stroke: "#1e4d8c"
    border-radius: 10
  }
}

Code Generator: {
  label: "Code Generator\ncodegen.py\nJOIN, CASE WHEN\nUNPIVOT, QUALIFY"
  style: {
    fill: "#285faa"
    font-color: "#ffffff"
    stroke: "#1e4d8c"
    border-radius: 10
